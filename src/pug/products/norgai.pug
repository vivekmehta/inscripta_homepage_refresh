                        img.img-fluid.dashboard-screenshot(src='/assets/img/dashboard_ss.png' alt='NorgAI Dashboard')


            // Plugins Section
            section#plugins.page-section.plugins-section
                .container.px-4.px-lg-5

                    // Section Header
                    .row.justify-content-center.mb-6
                        .col-lg-8.text-center
                            .section-badge.mb-3
                                span 🔌 Native Plugins
                            h2.section-heading Built into the tools your team already uses
