doctype html
html(lang='en')

    head
        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content='NorgAI streamlines Professional Services delivery with features like hierarchical memory, traceability, adaptive templates, and AI document generation for faster, higher-quality outcomes.')
        meta(name='author', content='Team Inscripta')

        title GenAI Assistant for Professional Services Teams

        // Favicon
        link(rel='icon', type='image/x-icon', href='/assets/favicon.png')

        //Font
        link(rel="preconnect" href="https://fonts.gstatic.com") 

        link(rel='preload' href='https://fonts.googleapis.com/css?family=Lato:300,400,400i,700,700i,900&display=swap' as='style' onload="this.onload=null;this.rel='stylesheet'")
        noscript
            link(href='https://fonts.googleapis.com/css?family=Lato:300,400,400i,700,700i,900&display=swap', rel='stylesheet')

        link(rel='preload' href='https://fonts.googleapis.com/css?family=Nunito Sans:300,400,400i,700,700i,900&display=swap' as='style' onload="this.onload=null;this.rel='stylesheet'")
        noscript
            link(href='https://fonts.googleapis.com/css?family=Nunito Sans:300,400,400i,700,700i,900&display=swap', rel='stylesheet')

        link(rel='preload' href='https://use.fontawesome.com/releases/v5.3.1/css/all.css' as='style' onload="this.onload=null;this.rel='stylesheet'")
        noscript
            link(href='https://use.fontawesome.com/releases/v5.3.1/css/all.css', rel='stylesheet')

        link(rel='stylesheet' href='/css/norgai-critical.css')

        // Google Tag Manager
