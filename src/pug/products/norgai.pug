            section#dashboard-hub.page-section.dashboard-hub-section
                .container.px-4.px-lg-5

                    // Header
                    .row.justify-content-center.mb-5
                        .col-lg-7.text-center
                            .section-badge.mb-3
                                span 🖥️ NorgAI Dashboard
                            h2.section-heading Your Central Command Center

                    // 4 feature points in a 2x2 grid ABOVE the image
                    .row.g-3.mb-5
                        .col-lg-3.col-md-6
                            .dfi-card
                                .dfi-card-icon
                                    i.fas.fa-folder-open
                                p.dfi-card-title Project Hub
                                p.dfi-card-desc Manage all projects, stages and artifacts in one place
                        .col-lg-3.col-md-6
                            .dfi-card
                                .dfi-card-icon
                                    i.fas.fa-magic
                                p.dfi-card-title Central Artifact Generation
                                p.dfi-card-desc Generate any document from the lifecycle
                        .col-lg-3.col-md-6
                            .dfi-card
                                .dfi-card-icon
                                    i.fas.fa-comments
                                p.dfi-card-title Integrated AI Chat
                                p.dfi-card-desc Full project context in every single conversation
                        .col-lg-3.col-md-6
                            .dfi-card
                                .dfi-card-icon
                                    i.fas.fa-brain
                                p.dfi-card-title Persistent Memory
                                p.dfi-card-desc Context flows from first RFP to final delivery automatically

                    // Screenshot below as proof
