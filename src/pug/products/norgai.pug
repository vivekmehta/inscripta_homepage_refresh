    body#page-top

        // Google Tag Manager (noscript)
        noscript
            iframe(src='https://www.googletagmanager.com/ns.html?id=GTM-5XQVFGS' height='0' width='0' style='display:none;visibility:hidden')
        // End Google Tag Manager (noscript)


        // Navigation
        include /pug/includes/menu.pug

        .norgai-hero-wrapper

            // Producthead
            header.prodhead (role="banner")
                .container.px-4.px-lg-5
                    .row.gx-5.align-items-center.position-relative
                        // LEFT TEXT — 5 columns
                        .col-lg-6.col-md-12.text-section.hero-content
                            // Badge
                            .hero-badge.mb-4
                                span.badge-icon ⚡
                                span Professional Services AI
                            
                            h1.text-white.font-weight-bold.hero-title.mb-4 NorgAI
                            h4.text-white.mt-3.mb-4.font-weight-bold(style="letter-spacing: 2px; text-transform: uppercase;") AI Business Analyst Agent
                            h5.text-white.mt-4.hero-subtitle Transform RFPs, sales notes, client clarifications into high quality proposals, SOWs, use cases, requirements and implementation ready documentation cutting documentation effort by 50%, reducing rework while keeping your team in control.
                            
                            // CTA Buttons
                            .mt-5
                                a.btn.btn-hero-primary(href='#animation-section') 
                                    span Learn More
                                    i.fas.fa-arrow-right.ms-2

                        // RIGHT ANIMATION — 7 columns
                        .col-lg-6.col-md-12
                            .hero-video-container
                                .workflow-wrapper   
                                    .workflow-content
                                        // Header Badge
                                        .badge-wrapper.fade-in-item
                                            .badge.pulse-badge
                                                span.badge-text FROM RFP TO GO-LIVE
                                        // Title
                                        //- h1.title.fade-in-item How NorgAI Streamlines Your Workflow

                                        .steps-container
                                            // Step 1: Ingest
                                            .step-wrapper.fade-in-item
                                                .step-card.step-blue
                                                    .step-content
                                                        .step-number.step-number-blue 1
                                                        .step-text
                                                            h2.step-title Ingest
                                                            p.step-description.text-blue RFPs, sales notes, clarifications
                                                    .glow-effect.glow-blue

                                            // Arrow 1
                                            .arrow-wrapper.fade-in-item
                                                .arrow-container
                                                    svg.arrow-icon.bounce-arrow(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                                                        polyline(points="6 9 12 15 18 9")

                                            // Step 2: Generate
                                            .step-wrapper.fade-in-item
                                                .step-card.step-red
                                                    .step-content
                                                        .step-number.step-number-red 2
                                                        .step-text
                                                            h2.step-title Generate
                                                            p.step-description.text-red Structured proposals, use cases, requirements
                                                    .glow-effect.glow-red

                                            // Arrow 2
                                            .arrow-wrapper.fade-in-item
                                                .arrow-container
                                                    svg.arrow-icon.bounce-arrow.bounce-arrow-2(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                                                        polyline(points="6 9 12 15 18 9")

                                            // Step 3: Deliver
                                            .step-wrapper.fade-in-item
                                                .step-card.step-indigo
                                                    .step-content
                                                        .step-number.step-number-indigo 3
                                                        .step-text
                                                            h2.step-title Deliver
                                                            p.step-description.text-blue Implementation-ready SOWs and documentation
                                                    .glow-effect.glow-indigo
                                                    .success-pulse

                        // Trust indicators
                        .hero-trust.mt-4
                            .trust-item
                                i.fas.fa-shield-alt.text-secondary
                                span Purpose-built for PS
                            .trust-item
                                i.fas.fa-lock.text-secondary
                                span On-Prem Option
                            .trust-item
                                i.fas.fa-server.text-secondary
                                span Native Word & PowerPoint Plugins

            
            // Value Proposition - Scroll Reveal
            section.scroll-value-section
                .container.px-4.px-lg-5
                    .scroll-value-wrapper
                        .scroll-value-text
                            span.reveal-word(data-word="1") TRANSFORM
                            | &nbsp;
                            span.reveal-word(data-word="2") COMPLEXITY
                            | &nbsp;
                            span.reveal-word(data-word="3") INTO
                            | &nbsp;
                            span.reveal-word(data-word="4") CLARITY

            
            // Concept Animation Section
            section#animation-section.animation-section
                .background-effects
                    .glow-effect.glow-blue
                    .glow-effect.glow-purple

                .section-header
                    h2.main-title Your AI Business Analyst Agent for Professional Services
                    p.subtitle From input to implementation-ready documentation

                .workflow-container
                    .workflow-grid
                        
                        // Input Documents
                        .workflow-column#input-column
                            h3.column-title.input-title Input
                            
                            .doc-card(data-index="0")
                                .doc-card-gradient.gradient-blue
                                    .doc-card-content
                                        svg.doc-icon(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                                            path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z")
                                            polyline(points="14 2 14 8 20 8")
                                        span.doc-label RFPs
                                .connection-line.connection-left

                            .doc-card(data-index="1")
                                .doc-card-gradient.gradient-purple
                                    .doc-card-content
                                        svg.doc-icon(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                                            path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z")
                                            polyline(points="14 2 14 8 20 8")
                                            line(x1="16" y1="13" x2="8" y2="13")
                                            line(x1="16" y1="17" x2="8" y2="17")
                                        span.doc-label Sales Notes
                                .connection-line.connection-left

                            .doc-card(data-index="2")
                                .doc-card-gradient.gradient-orange
                                    .doc-card-content
                                        svg.doc-icon(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                                            path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z")
                                            polyline(points="14 2 14 8 20 8")
                                        span.doc-label Client Clarifications
                                .connection-line.connection-left

                        // AI Processing Core
                        .workflow-column#core-column
                            .ai-core-container
                                .ai-core
                                    .core-ring.outer-ring
                                    .core-ring.middle-ring
                                    .core-center
                                        .core-center-inner
                                            img.core-logo(src='/assets/img/QAbot_logo_Final.png' alt='NorgAI')

                                .core-label
                                    span.label-text NorgAI

                        // Output Documents
                        .workflow-column#output-column
                            h3.column-title.output-title Output
                            
                            .doc-card(data-index="0")
                                .connection-line.connection-right
                                .doc-card-gradient.gradient-green
                                    .doc-card-content
                                        svg.doc-icon(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                                            path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z")
                                            polyline(points="14 2 14 8 20 8")
                                            polyline(points="9 15 11 17 15 13")
                                        span.doc-label Proposals

                            .doc-card(data-index="1")
                                .connection-line.connection-right
                                .doc-card-gradient.gradient-teal
                                    .doc-card-content
                                        svg.doc-icon(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                                            path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z")
                                            polyline(points="14 2 14 8 20 8")
                                        span.doc-label Statements of Work

                            .doc-card(data-index="2")
                                .connection-line.connection-right
                                .doc-card-gradient.gradient-indigo
                                    .doc-card-content
                                        svg.doc-icon(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                                            path(d="M22 11.08V12a10 10 0 1 1-5.93-9.14")
                                            polyline(points="22 4 12 14.01 9 11.01")
                                        span.doc-label Requirements Use Cases

                            .doc-card(data-index="3")
                                .connection-line.connection-right
                                .doc-card-gradient.gradient-violet
                                    .doc-card-content
                                        svg.doc-icon(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2")
                                            path(d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z")
                                            polyline(points="14 2 14 8 20 8")
                                            line(x1="16" y1="13" x2="8" y2="13")
                                            line(x1="16" y1="17" x2="8" y2="17")
                                        span.doc-label Documentation

            // Value Proposition
            section.value-section
                .value-content
                    p.value-text
                        | Seamlessly integrating with your existing tools, NorgAI understands your workflows 
                        | and preserves context from pre-sales through delivery. The result: 
                        span.highlight-blue faster execution
                        | , 
                        span.highlight-green reduced manual rework
                        | , and 
                        span.highlight-purple more predictable go-lives
                        | —while keeping your team firmly in control.

        main(role="main")
            // Key Features Section
            section#key-features.page-section.key-features-modern
                .container.px-4.px-lg-5
                    .row.justify-content-center.mb-5
                        .col-lg-10.text-center
                            .section-badge.mb-3
                                span Core Capabilities
                            h2.section-heading Why Teams Choose NorgAI
                            p.section-subheading Built specifically for Professional Services workflows—not a generic AI chatbot
                    
                    .row.g-4
                        .col-lg-6.col-md-6
                            .key-feature-card
                                .feature-card-inner
                                    .feature-number 01
                                    .feature-icon-box
                                        i.fas.fa-plug
                                    h3.feature-card-title Native Plugins
                                    p.feature-card-text Purpose-built plugins for MS PowerPoint, Word, Google Slides/Docs, and corporate templates.
                                    .feature-highlight
                                        i.fas.fa-check-circle
                                        span Direct Integration
                        
                        .col-lg-6.col-md-6
                            .key-feature-card
                                .feature-card-inner
                                    .feature-number 02
                                    .feature-icon-box
                                        i.fas.fa-brain
                                    h3.feature-card-title Intelligent Knowledge Reuse
                                    p.feature-card-text Learns from past proposals, SOWs, and delivery docs without requiring manual "master" document maintenance. Your institutional knowledge, automatically leveraged.
                                    .feature-highlight
                                        i.fas.fa-check-circle
                                        span Zero Maintenance
                        
                        .col-lg-6.col-md-6
                            .key-feature-card
                                .feature-card-inner
                                    .feature-number 03
                                    .feature-icon-box
                                        i.fas.fa-arrows-alt-h
                                    h3.feature-card-title Seamless Workflow
                                    p.feature-card-text No tool-switching or copy-paste—works directly within the tools your team already uses for maximum productivity.
                                    .feature-highlight
                                        i.fas.fa-check-circle
                                        span Zero Context Switching
                        
                        .col-lg-6.col-md-6
                            .key-feature-card
                                .feature-card-inner
                                    .feature-number 04
                                    .feature-icon-box
                                        i.fas.fa-shield-alt
                                    h3.feature-card-title On-Prem Deployment
                                    p.feature-card-text On-prem deployment option ensures your sensitive client data, proposals, and IP remain completely private and secure within your infrastructure.
                                    .feature-highlight
                                        i.fas.fa-check-circle
                                        span Your Data, Your Control
            
            
            // Main Feature Grid
            section#impact-metrics.page-section.impact-gradient
                .container.px-4.px-lg-5
                    .row.g-4
                        .col-lg-4.col-md-12
                            .stat-bar-card
                                .stat-bar-body
                                    .stat-number 60–70%
                                    .stat-info
                                        h3.stat-title Faster Document Creation
                                        p.stat-desc Accelerate RFP responses, proposals, and delivery artifacts through intelligent automation.
                                .stat-progress-track
                                    .stat-progress-fill(data-width="70")

                        .col-lg-4.col-md-12
                            .stat-bar-card
                                .stat-bar-body
                                    .stat-number 80%
                                    .stat-info
                                        h3.stat-title Less Rework
                                        p.stat-desc Driven by consistent structure, complete requirements Use Cases, and early gap detection across documents.
                                .stat-progress-track
                                    .stat-progress-fill(data-width="80")

                        .col-lg-4.col-md-12
                            .stat-bar-card
                                .stat-bar-body
                                    .stat-number 70%
                                    .stat-info
                                        h3.stat-title Smart Knowledge Reuse
                                        p.stat-desc Effective reuse without the overhead of manually maintaining master documents.
                                .stat-progress-track
                                    .stat-progress-fill(data-width="70")


            // Tools Comparison Matrix
            section#tools-matrix.page-section.tools-matrix-section
                .container.px-4.px-lg-5
                    .row.justify-content-center.mb-5
                        .col-lg-9.text-center
                            .section-badge.mb-3
                                span ⚡ Benchmark
                            h2.section-heading How NorgAI Stacks Up
                            p.section-subheading Tested head-to-head against popular AI tools on the workflows that matter most for PS teams

