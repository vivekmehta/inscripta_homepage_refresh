            // Modern PS Tasks Section
            section#ps-tasks.page-section
                .container.px-4.px-lg-5
                    .row.justify-content-center.mb-5
                        .col-lg-8.text-center
                            .section-badge.mb-3
                                span 💼 Capabilities
                            h2.section-heading How NorgAI Helps PS Teams
                            p.section-subheading Transform your Professional Services workflow with AI-powered automation
                    
                    .row.g-4.justify-content-center
